{
  "manifest_version": 2,
  "name": "Cookie Editor Pro",
  "version": "1.0.0",
  "description": "A powerful, beautiful cookie manager with glassmorphism UI. View, edit, delete, import and export cookies.",
  "permissions": [
    "cookies",
    "activeTab",
    "tabs",
    "clipboardWrite",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Cookie Editor Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-editor-pro@extension",
      "strict_min_version": "57.0"
    }
  }
}
